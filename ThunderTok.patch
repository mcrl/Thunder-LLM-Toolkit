+// A token and a score
+type SentencePiece = (String, f64);
+
+// A full sentence or word + it's count within the dataset
+type Sentence = (String, u32);
+
+fn digamma(mut x: f64) -> f64 {
+    let mut result = 0.0;
+    while x < 7.0 {
+        result -= 1.0 / x;
+        x += 1.0;
+    }
+    x -= 1.0 / 2.0;
+    let xx = 1.0 / x;
+    let xx2 = xx * xx;
+    let xx4 = xx2 * xx2;
+    result += x.ln() + (1.0 / 24.0) * xx2 - 7.0 / 960.0 * xx4 + (31.0 / 8064.0) * xx4 * xx2
+        - (127.0 / 30720.0) * xx4 * xx4;
+    result
+}
+
+fn bytes_char() -> HashMap<u8, char> {
+    let mut bs: Vec<u8> = vec![];
+    bs.extend(b'!'..=b'~');
+    bs.extend(b'\xA1'..=b'\xAC');
+    bs.extend(b'\xAE'..=b'\xFF');
+
+    let mut cs: Vec<u32> = bs.iter().map(|i| *i as u32).collect();
+    let mut n = 0;
+
+    for b in 0..=255u8 {
+        if !bs.contains(&b) {
+            bs.push(b);
+            cs.push(u32::pow(2, 8) + n);
+            n += 1;
+        }
+    }
+
+    bs.into_iter()
+        .zip(cs)
+        .map(|(f, t)| (f, unsafe { std::char::from_u32_unchecked(t) }))
+        .collect()
+}
+
+fn check_cond(s: &[char], map: &HashMap<char, u8>) -> bool {
+    let mut length = 0;
+    for c in s {
+        if let Some(&byte_value) = map.get(&c) {
+            if byte_value >= 0 && byte_value <= 127 {
+                length += 0;
+            } else if byte_value >= 192 && byte_value <= 223 {
+                length += 1;
+            } else if byte_value >= 224 && byte_value <= 239 {
+                length += 2;
+            } else if byte_value >= 240 && byte_value <= 247 {
+                length += 3;
+            } else {
+                length -= 1;
+            }
+            if length < 0 {
+                return true;
+            }
+        } else {
+            return true;
+        }
+    }
+
+    if length == 0 {
+        false
+    } else {
+        true
+    }
+}
